# Production (TestNeo Cloud) — use after you sign up and create an API key
TESTNEO_BASE_URL=https://app.testneo.ai
TESTNEO_API_KEY=tn_your_key_here

# Self-hosted / local API only (omit for normal cloud usage)
# TESTNEO_BASE_URL=http://localhost:8001
#
# SPA deep links (execution dashboard) — API is often :8001, Vite dev UI :5173
# TESTNEO_WEB_APP_URL=http://localhost:5173
# Optional path before /test-runner/... (matches /web/test-runner/* routes), e.g. /web
# TESTNEO_WEB_APP_PATH_PREFIX=/web

# Optional
# TESTNEO_MCP_ALLOW_WRITE=false
# TESTNEO_MCP_RELAX_PROJECT_PRECONDITIONS=false
# TESTNEO_MCP_TELEMETRY_JSONL=false
# TESTNEO_MCP_POLICY_MODE=strict
# TESTNEO_MCP_TIMEOUT_MS=20000
# TESTNEO_MCP_SWAGGER_TIMEOUT_MS=120000
# TESTNEO_MCP_USER_AGENT=@testneo/mcp-server
#
# Multi-test / batch-by-tags defaults (testneo_run_batch_by_tags)
# TESTNEO_MCP_DEFAULT_EXECUTION_MODE=local
# TESTNEO_MCP_DEFAULT_EXECUTION_PLATFORM=local
# TESTNEO_MCP_PREFER_LOCAL_AGENT=true
# TESTNEO_MCP_REQUIRE_LOCAL_AGENT_FOR_BATCH=true
# Poll my-agent before batch when use_agent (0 = single check only). Example: 60000 = up to 60s for you to start the agent after invoking MCP.
# TESTNEO_MCP_WAIT_FOR_AGENT_MS=0
# On hard agent failure (not registered / not connected after wait), try opening setup in the default browser once (best-effort).
# TESTNEO_MCP_OPEN_AGENT_SETUP_ON_AGENT_FAILURE=false
